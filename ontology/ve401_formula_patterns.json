      "procedure": "chi_square_variance",
      "task_type": "hypothesis_test",
      "parameter": "sigma_squared",
      "keywords": ["chi-square", "chi square", "test variance", "test sigma", "test whether sigma", "standard deviation", "sample standard deviation", "sample variance", "s squared", "one-sided test", "spread is below", "variability requirement"],
      "regex": ["\\\\chi\\^2", "\\(n\\s*-\\s*1\\)\\s*s\\^2", "sigma_?0\\^2", "\\\\sigma\\^2", "s\\^2\\s*=\\s*\\d", "s\\s+squared\\s+\\d", "sigma\\s+is\\s+greater", "sigma\\s*>", "standard\\s+deviation\\s+is\\s+at\\s+most", "sample\\s+standard\\s+deviation"],
      "assumptions": ["normal_population"]
    },
    {
      "id": "fisher_p_value_test",
      "label": "Fisher significance test and P-value evidence",
      "method_family": "fisher_test",
      "procedure": "fisher_significance_test",
      "task_type": "hypothesis_test",
      "parameter": "unknown",
      "keywords": ["fisher", "p-value", "p value", "evidence against", "null hypothesis", "significance test"],
      "regex": ["P\\s*<\\s*0\\.05", "p-?value", "H_0", "reject\\s+H_0"],
      "assumptions": []
    },
    {
