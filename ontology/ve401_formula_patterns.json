      "method_family": "interval_estimation",
      "procedure": "one_sample_t_mean",
      "task_type": "confidence_interval",
      "parameter": "mu",
      "keywords": ["unknown sigma", "sample standard deviation", "t interval", "t test", "normal population", "xbar", "two-sided alternative"],
      "regex": ["t_\\{?\\\\alpha/2", "\\\\bar\\s*x\\s*\\\\pm\\s*t", "s/\\\\sqrt\\s*\\{?n\\}?", "df\\s*=\\s*n\\s*-\\s*1", "\\bxbar\\b.*\\bs\\b", "\\bs\\b.*\\bxbar\\b"],
      "assumptions": ["unknown_sigma", "normal_population_or_large_sample"]
    },
    {
      "id": "chi_square_variance_pivot",
