{
  "version": 2,
  "patterns": [
    {
      "id": "known_variance_mean_z",
      "label": "Known-variance Z inference for one mean",
      "method_family": "interval_estimation",
      "procedure": "one_sample_z_mean",
      "task_type": "confidence_interval",
      "parameter": "mu",
      "keywords": ["known standard deviation", "known variance", "known sigma", "long-run calibration", "long-run sigma", "z interval", "population standard deviation", "interval estimate for the process mean", "confidence interval for the true mean"],
      "regex": ["z_\\{?\\\\alpha/2", "\\\\bar\\s*x\\s*\\\\pm\\s*z", "sigma/\\\\sqrt\\s*\\{?n\\}?", "\\\\sigma/\\\\sqrt\\s*\\{?n\\}?", "known\\s+population\\s+standard\\s+deviation", "sigma\\s*=\\s*\\d+(?:\\.\\d+)?.*long[-\\s]run", "long[-\\s]run\\s+calibration", "interval\\s+estimate\\s+for\\s+the\\s+process\\s+mean"],
      "assumptions": ["known_sigma", "normal_or_large_sample"]
    },
    {
      "id": "known_variance_mean_z_test",
      "label": "Known-variance Z test for one mean",
      "method_family": "single_sample_tests",
      "procedure": "one_sample_z_mean",
      "task_type": "hypothesis_test",
      "parameter": "mu",
      "keywords": ["known standard deviation", "known variance", "known sigma", "population standard deviation", "z test", "known population standard deviation"],
      "regex": ["known\\s+population\\s+standard\\s+deviation", "population\\s+standard\\s+deviation\\s+is\\s+known", "\\bsigma\\b.*known", "test\\s+.*mean\\s+is\\s+(?:larger|smaller|different|not)"],
      "assumptions": ["known_sigma", "normal_or_large_sample"]
    },
    {
      "id": "unknown_variance_mean_t",
