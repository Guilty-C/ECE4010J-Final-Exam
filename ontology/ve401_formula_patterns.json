      "regex": ["\\\\beta", "1\\s*-\\s*\\\\beta", "critical\\s+region", "type\\s+i", "cutoff\\s+(?:chosen\\s+)?before\\s+(?:seeing\\s+)?data", "power\\s+at\\s+a\\s+larger\\s+mean", "probability\\s+of\\s+rejecting\\s+under\\s+(?:the\\s+)?alternative", "missing\\s+a\\s+.*shift"],
      "assumptions": []
