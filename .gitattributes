* text=auto eol=lf

# Force LF for source code
*.py     text eol=lf
*.sh     text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.jsonl  text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.toml   text eol=lf

# Git LFS — model adapters and large indexes
*.safetensors  filter=lfs diff=lfs merge=lfs -text
*.bin          filter=lfs diff=lfs merge=lfs -text
*.gguf         filter=lfs diff=lfs merge=lfs -text
*.faiss        filter=lfs diff=lfs merge=lfs -text
